{
  "manifest_version": 2,
  "name": "BBE No Logout",
  "version": "1.0.0",
  "description": "Disables the 30-minute auto-logoff timer in Big Bang Empire.",
  "author": "Anestory",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "BBENoLogout@Anestory",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "https://bbe-static.akamaized.net/assets/html5/BBE.min.js"
  ],
  "background": {
    "scripts": ["background.js"]
  }
}
